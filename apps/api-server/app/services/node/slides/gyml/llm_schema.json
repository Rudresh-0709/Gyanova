{
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "description": "Slide title"
        },
        "subtitle": {
            "type": "string",
            "description": "Optional subtitle"
        },
        "layout": {
            "type": "string",
            "enum": [
                "right",
                "left",
                "top",
                "behind",
                "blank"
            ],
            "description": "The visual layout orientation for the accent image"
        },
        "intent": {
            "type": "string",
            "enum": [
                "introduce",
                "explain",
                "narrate",
                "compare",
                "list",
                "prove",
                "summarize",
                "teach",
                "demo"
            ],
            "description": "The semantic intent of the slide"
        },
        "contentBlocks": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "type": "object",
                        "title": "Intro Paragraph",
                        "properties": {
                            "type": {
                                "const": "intro_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Context Paragraph",
                        "properties": {
                            "type": {
                                "const": "context_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Annotation Paragraph",
                        "properties": {
                            "type": {
                                "const": "annotation_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Outro Paragraph",
                        "properties": {
                            "type": {
                                "const": "outro_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Caption",
                        "properties": {
                            "type": {
                                "const": "caption"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Paragraph",
                        "properties": {
                            "type": {
                                "const": "paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Smart Layout",
                        "properties": {
                            "type": {
                                "const": "smart_layout"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "timeline",
                                    "timelineHorizontal",
                                    "timelineSequential",
                                    "timelineMilestone",
                                    "cardGrid",
                                    "cardGridIcon",
                                    "cardGridSimple",
                                    "cardGridImage",
                                    "stats",
                                    "statsComparison",
                                    "statsPercentage",
                                    "bigBullets",
                                    "bulletIcon",
                                    "bulletCheck",
                                    "bulletCross",
                                    "processSteps",
                                    "processArrow",
                                    "processAccordion",
                                    "comparison",
                                    "comparisonProsCons",
                                    "comparisonBeforeAfter",
                                    "quote",
                                    "quoteTestimonial",
                                    "quoteCitation",
                                    "definition",
                                    "codeSnippet",
                                    "codeComparison",
                                    "diagramFlowchart",
                                    "diagramHierarchy",
                                    "diagramCycle",
                                    "diagramPyramid",
                                    "table",
                                    "tableStriped",
                                    "tableHighlight"
                                ]
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true
                                }
                            }
                        },
                        "required": [
                            "type",
                            "variant",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Process Arrow Block",
                        "properties": {
                            "type": {
                                "const": "process_arrow_block"
                            },
                            "items": {
                                "type": "array",
                                "minItems": 2,
                                "maxItems": 4,
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "Short label for the process step (3-5 words)"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "Short explanation below the arrow (10-15 words)"
                                        },
                                        "imagePrompt": {
                                            "type": "string",
                                            "description": "Vivid, atmospheric prompt for a simple drawing/art representing this step. No words in the image."
                                        },
                                        "color": {
                                            "type": "string",
                                            "description": "Hex color for this step"
                                        }
                                    },
                                    "required": [
                                        "label",
                                        "imagePrompt"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Cyclic Process Block",
                        "properties": {
                            "type": {
                                "const": "cyclic_process_block"
                            },
                            "items": {
                                "type": "array",
                                "minItems": 2,
                                "maxItems": 4,
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "label": {
                                            "type": "string",
                                            "description": "Short title (3-5 words)"
                                        },
                                        "description": {
                                            "type": "string",
                                            "description": "Short explanation (8-12 words)"
                                        },
                                        "imagePrompt": {
                                            "type": "string",
                                            "description": "Vivid prompt for a simple drawing. No words."
                                        }
                                    },
                                    "required": [
                                        "label",
                                        "imagePrompt"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Timeline (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "timeline"
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "year": {
                                            "type": "string"
                                        },
                                        "description": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "year",
                                        "description"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Card Grid (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "card_grid"
                            },
                            "cards": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "heading": {
                                            "type": "string"
                                        },
                                        "text": {
                                            "type": "string"
                                        },
                                        "icon": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "heading",
                                        "text"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "cards"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Stats (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "stats"
                            },
                            "stats": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "value": {
                                            "type": "string"
                                        },
                                        "label": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "value",
                                        "label"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "stats"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Code Block",
                        "properties": {
                            "type": {
                                "const": "code"
                            },
                            "code": {
                                "type": "string"
                            },
                            "language": {
                                "type": "string",
                                "default": "python"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "snippet",
                                    "comparison"
                                ],
                                "default": "snippet"
                            }
                        },
                        "required": [
                            "type",
                            "code"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Table",
                        "properties": {
                            "type": {
                                "const": "table"
                            },
                            "headers": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "simple",
                                    "striped",
                                    "highlight"
                                ],
                                "default": "simple"
                            }
                        },
                        "required": [
                            "type",
                            "headers",
                            "rows"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Quote",
                        "properties": {
                            "type": {
                                "const": "quote"
                            },
                            "text": {
                                "type": "string"
                            },
                            "author": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "quote",
                                    "quoteTestimonial",
                                    "quoteCitation"
                                ],
                                "default": "quote"
                            }
                        },
                        "required": [
                            "type",
                            "text",
                            "author"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Image",
                        "properties": {
                            "type": {
                                "const": "image"
