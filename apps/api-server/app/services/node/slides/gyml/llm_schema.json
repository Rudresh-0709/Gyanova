                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "caption": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "headers",
                            "rows"
                        ]
                    },
