{
    "type": "object",
    "properties": {
        "title": {
            "type": "string",
            "description": "Slide title"
        },
        "subtitle": {
            "type": "string",
            "description": "Optional subtitle"
        },
        "intent": {
            "type": "string",
            "enum": [
                "introduce",
                "explain",
                "narrate",
                "compare",
                "list",
                "prove",
                "summarize",
                "teach",
                "demo"
            ],
            "description": "The semantic intent of the slide"
        },
        "contentBlocks": {
            "type": "array",
            "items": {
                "oneOf": [
                    {
                        "type": "object",
                        "title": "Intro Paragraph",
                        "properties": {
                            "type": {
                                "const": "intro_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Context Paragraph",
                        "properties": {
                            "type": {
                                "const": "context_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Annotation Paragraph",
                        "properties": {
                            "type": {
                                "const": "annotation_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Outro Paragraph",
                        "properties": {
                            "type": {
                                "const": "outro_paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Caption",
                        "properties": {
                            "type": {
                                "const": "caption"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Paragraph",
                        "properties": {
                            "type": {
                                "const": "paragraph"
                            },
                            "text": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Smart Layout",
                        "properties": {
                            "type": {
                                "const": "smart_layout"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "timeline",
                                    "timelineHorizontal",
                                    "timelineSequential",
                                    "timelineMilestone",
                                    "cardGrid",
                                    "cardGridIcon",
                                    "cardGridSimple",
                                    "cardGridImage",
                                    "stats",
                                    "statsComparison",
                                    "statsPercentage",
                                    "bigBullets",
                                    "bulletIcon",
                                    "bulletCheck",
                                    "bulletCross",
                                    "processSteps",
                                    "processArrow",
                                    "processAccordion",
                                    "comparison",
                                    "comparisonProsCons",
                                    "comparisonBeforeAfter",
                                    "quote",
                                    "quoteTestimonial",
                                    "quoteCitation",
                                    "definition",
                                    "codeSnippet",
                                    "codeComparison",
                                    "diagramFlowchart",
                                    "diagramHierarchy",
                                    "diagramCycle",
                                    "diagramPyramid",
                                    "table",
                                    "tableStriped",
                                    "tableHighlight"
                                ]
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true
                                }
                            }
                        },
                        "required": [
                            "type",
                            "variant",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Timeline (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "timeline"
                            },
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "year": {
                                            "type": "string"
                                        },
                                        "description": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "year",
                                        "description"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "items"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Card Grid (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "card_grid"
                            },
                            "cards": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "heading": {
                                            "type": "string"
                                        },
                                        "text": {
                                            "type": "string"
                                        },
                                        "icon": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "heading",
                                        "text"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "cards"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Stats (Legacy Format)",
                        "properties": {
                            "type": {
                                "const": "stats"
                            },
                            "stats": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "properties": {
                                        "value": {
                                            "type": "string"
                                        },
                                        "label": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "value",
                                        "label"
                                    ]
                                }
                            }
                        },
                        "required": [
                            "type",
                            "stats"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Code Block",
                        "properties": {
                            "type": {
                                "const": "code"
                            },
                            "code": {
                                "type": "string"
                            },
                            "language": {
                                "type": "string",
                                "default": "python"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "snippet",
                                    "comparison"
                                ],
                                "default": "snippet"
                            }
                        },
                        "required": [
                            "type",
                            "code"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Table",
                        "properties": {
                            "type": {
                                "const": "table"
                            },
                            "headers": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "rows": {
                                "type": "array",
                                "items": {
                                    "type": "array",
                                    "items": {
                                        "type": "string"
                                    }
                                }
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "simple",
                                    "striped",
                                    "highlight"
                                ],
                                "default": "simple"
                            }
                        },
                        "required": [
                            "type",
                            "headers",
                            "rows"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Quote",
                        "properties": {
                            "type": {
                                "const": "quote"
                            },
                            "text": {
                                "type": "string"
                            },
                            "author": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            },
                            "variant": {
                                "type": "string",
                                "enum": [
                                    "quote",
                                    "quoteTestimonial",
                                    "quoteCitation"
                                ],
                                "default": "quote"
                            }
                        },
                        "required": [
                            "type",
                            "text",
                            "author"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Image",
                        "properties": {
                            "type": {
                                "const": "image"
                            },
                            "url": {
                                "type": "string"
                            },
                            "caption": {
                                "type": "string"
                            },
                            "layout": {
                                "type": "string",
                                "enum": [
                                    "left",
                                    "right",
                                    "top",
                                    "behind",
                                    "blank"
                                ],
                                "default": "right"
                            }
                        },
                        "required": [
                            "type",
                            "url"
                        ]
                    },
                    {
                        "type": "object",
                        "title": "Callout / Takeaway",
                        "properties": {
                            "type": {
                                "type": "string",
                                "enum": [
                                    "callout",
                                    "takeaway"
                                ]
                            },
                            "text": {
                                "type": "string"
                            },
                            "label": {
                                "type": "string"
                            },
                            "icon": {
                                "type": "string"
                            }
                        },
                        "required": [
                            "type",
                            "text"
                        ]
                    }
                ]
            }
        },
        "takeaway": {
            "type": "string",
            "description": "Key takeaway message (optional if using takeaway block)"
        },
        "imagePrompt": {
            "type": "string",
            "description": "Prompt for generative image"
        }
    },
    "required": [
        "title",
        "intent",
        "contentBlocks"
    ]
}