                                "type": "string"
                            },
                            "caption": {
                                "type": "string"
                            },
                            "layout": {
                                "type": "string",
                                "enum": [
                                    "left",
                                    "right",
                                    "top",
                                    "behind",
                                    "blank"
                                ],
                                "default": "right"
